{
	"$schema"     : "https://json-schema.org/draft/2020-12/schema",
	"title"       : "Starter Extension Settings",
	"description" : "Configuration for the starter extension",
	"type"        : "object",
	"properties"  : {
		"greeting": {
			"type"        : "string",
			"field"       : "text",
			"label"       : "Greeting Message",
			"help"        : "The greeting used by the extension's Twig function and API endpoint",
			"placeholder" : "Hello",
			"default"     : "Hello"
		}
	}
}
