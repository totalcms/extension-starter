{
    "id": "acme/starter",
    "name": "Starter Extension",
    "description": "A starter template for building Total CMS extensions",
    "version": "1.0.0",
    "requires": {
        "totalcms": ">=3.3.0",
        "php": ">=8.2"
    },
    "permissions": [
        "twig:functions",
        "twig:filters",
        "cli:commands",
        "routes:admin",
        "admin:nav",
        "admin:widgets",
        "events:listen",
        "settings:read"
    ],
    "min_edition": "lite",
    "entrypoint": "Extension.php",
    "settings_schema": "settings-schema.json",
    "author": {
        "name": "Your Name",
        "url": "https://your-site.com"
    },
    "license": "MIT"
}
