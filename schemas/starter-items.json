{
    "id": "starter-items",
    "description": "Example schema provided by the starter extension",
    "category": "starter",
    "properties": {
        "title": {
            "type": "string",
            "field": "text",
            "label": "Title",
            "placeholder": "Enter a title"
        },
        "color": {
            "type": "string",
            "field": "colorpicker",
            "label": "Accent Color",
            "default": "#3B82F6"
        },
        "content": {
            "type": "string",
            "field": "styledtext",
            "label": "Content"
        },
        "priority": {
            "type": "number",
            "field": "number",
            "label": "Priority",
            "default": 0
        }
    },
    "required": ["id", "title"],
    "index": ["id", "title", "priority"]
}
